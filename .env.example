# ──────────────────────────────────────────────────────────────────────────────
# Meeting SaaS — Environment Variable Reference
#
# Copy this file to .env and fill in the real values.
# Never commit the real .env to version control.
#
# Deployment environments supported by this config:
#   - localhost (default values shown below)
#   - Cloudflare Tunnel / ngrok (replace URLs with tunnel URL)
#   - Staging / Production (replace URLs with your real domain)
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret"

# ── Google OAuth (for per-user Calendar integration) ─────────────────────────
# The redirect URI MUST be registered in the Google Cloud Console OAuth client.
# For local dev:           http://localhost:8000/calendar/callback
# For Cloudflare/ngrok:    https://<tunnel-id>.trycloudflare.com/calendar/callback
# For production:          https://api.yourdomain.com/calendar/callback
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:8000/calendar/callback"

# ── SendGrid Email Provider ───────────────────────────────────────────────────
# REQUIRED FOR EMAIL CAPABILITIES:
# 1. Sign up for SendGrid and verify a sending domain (SPF/DKIM)
# 2. Generate an API key with 'Mail Send' permissions
# 3. Choose the corresponding "from" address
SENDGRID_API_KEY="SG.your-api-key-here"
SENDGRID_FROM_EMAIL="notifications@yourdomain.com"

# ── URL Configuration ─────────────────────────────────────────────────────────
# Public URL where the React frontend is served.
# Used to build manage-booking, reschedule, cancel, onboarding, and
# calendar-connect links inside transactional emails.
#
# Local dev:           http://localhost:5173
# Cloudflare/ngrok:    https://<tunnel-id>.trycloudflare.com
# Production:          https://app.yourdomain.com
FRONTEND_URL="http://localhost:5173"

# Public URL where this FastAPI backend is served.
# Used for CORS validation and may be referenced in callback URLs.
#
# Local dev:           http://localhost:8000
# Cloudflare/ngrok:    https://<tunnel-id>.trycloudflare.com
# Production:          https://api.yourdomain.com
BACKEND_URL="http://localhost:8000"

# Comma-separated list of origins the browser is allowed to make cross-origin
# requests from. Must include every hostname your frontend is served from.
#
# Local dev:           http://localhost:5173
# Staging + prod:      https://app.yourdomain.com
# Multiple origins:    http://localhost:5173,https://app.yourdomain.com
CORS_ALLOWED_ORIGINS="http://localhost:5173"
